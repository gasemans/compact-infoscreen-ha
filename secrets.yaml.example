# Kopieer dit bestand naar 'secrets.yaml' (zonder .example) in dezelfde map
# en vul je eigen gegevens in. secrets.yaml wordt door ESPHome automatisch
# gebruikt via de !secret verwijzingen in compact-infoscreen-ha.yaml, en hoort
# NIET in git/GitHub terecht te komen (zie .gitignore).

wifi_ssid: "JouwWifiNaam"
wifi_password: "JouwWifiWachtwoord"

# Genereer je eigen, unieke sleutel - gebruik NOOIT een sleutel uit een
# voorbeeld/tutorial. Kan bijvoorbeeld met dit Python-commando:
#   python3 -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# Of laat ESPHome er automatisch een genereren door de regel
# 'key: !secret api_encryption_key' in compact-infoscreen-ha.yaml tijdelijk te
# vervangen door alleen 'key:' (leeg) en de yaml te compileren.
api_encryption_key: "VUL_HIER_JE_EIGEN_GEGENEREERDE_SLEUTEL_IN"
